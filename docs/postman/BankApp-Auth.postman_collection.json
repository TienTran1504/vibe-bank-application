{
  "info": {
    "name": "BankApp — Auth Service",
    "description": "All auth endpoints for the BankApp auth-service running on :8001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8001", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Register",
      "event": [],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"tien@example.com\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"+84901234567\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Register a new user. Password rules: min 8 chars, must contain uppercase, lowercase, digit, and special character (@$!%*?&)."
      },
      "response": [
        {
          "name": "201 Created",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"message\": \"Registration successful\",\n  \"timestamp\": \"2026-06-18T12:30:08.188Z\"\n}"
        },
        {
          "name": "409 Conflict — email already registered",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"CONFLICT\",\n  \"message\": \"Email already registered\",\n  \"timestamp\": \"2026-06-18T12:30:08.188Z\",\n  \"traceId\": \"abc-123\"\n}"
        },
        {
          "name": "400 Validation Failed",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"VALIDATION_FAILED\",\n  \"message\": \"Invalid input\",\n  \"details\": [\n    { \"field\": \"password\", \"message\": \"Password must contain uppercase, lowercase, digit, and special character\" }\n  ],\n  \"timestamp\": \"2026-06-18T12:30:08.188Z\",\n  \"traceId\": \"abc-123\"\n}"
        }
      ]
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.data) {",
              "  pm.collectionVariables.set('access_token', json.data.accessToken);",
              "  pm.collectionVariables.set('refresh_token', json.data.refreshToken);",
              "  console.log('Tokens saved to collection variables');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"tien@example.com\",\n  \"password\": \"Test@1234\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Login and get JWT pair. The test script auto-saves access_token and refresh_token to collection variables so all subsequent requests use them automatically."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"refreshToken\": \"a4551938-a9cb-4c6d-8bd8-19bd28c2aba8\",\n    \"expiresIn\": 900,\n    \"requiresMfa\": false\n  },\n  \"message\": \"Success\",\n  \"timestamp\": \"2026-06-18T12:30:18.973Z\"\n}"
        },
        {
          "name": "401 Wrong credentials",
          "status": "Unauthorized",
          "code": 401,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Invalid credentials\",\n  \"timestamp\": \"2026-06-18T12:30:18.973Z\",\n  \"traceId\": \"abc-123\"\n}"
        }
      ]
    },
    {
      "name": "3. Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.data) {",
              "  pm.collectionVariables.set('access_token', json.data.accessToken);",
              "  pm.collectionVariables.set('refresh_token', json.data.refreshToken);",
              "  console.log('Tokens rotated and saved');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api","v1","auth","refresh"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Exchange a refresh token for a new access + refresh token pair. Old refresh token is revoked (rotation). Test script auto-updates both variables."
      },
      "response": [
        {
          "name": "200 OK — new token pair",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...(new)\",\n    \"refreshToken\": \"b5662049-bab2-4d7e-9ce9-20ce39d3bcb9\",\n    \"expiresIn\": 900,\n    \"requiresMfa\": false\n  },\n  \"message\": \"Success\",\n  \"timestamp\": \"2026-06-18T12:31:00.000Z\"\n}"
        },
        {
          "name": "401 Expired / revoked token",
          "status": "Unauthorized",
          "code": 401,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Refresh token expired or revoked\",\n  \"timestamp\": \"2026-06-18T12:31:00.000Z\",\n  \"traceId\": \"abc-123\"\n}"
        }
      ]
    },
    {
      "name": "4. Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout"] },
        "body": { "mode": "raw", "raw": "" },
        "description": "Blacklists the current JWT by its JTI in Redis. Also revokes all refresh tokens for the user. The same access token will be rejected on subsequent requests."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"message\": \"Logged out successfully\",\n  \"timestamp\": \"2026-06-18T12:32:00.000Z\"\n}"
        },
        {
          "name": "401 No / invalid token",
          "status": "Unauthorized",
          "code": 401,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Invalid credentials\",\n  \"timestamp\": \"2026-06-18T12:32:00.000Z\",\n  \"traceId\": \"abc-123\"\n}"
        }
      ]
    },
    {
      "name": "5. MFA — Send OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/auth/mfa/send", "host": ["{{base_url}}"], "path": ["api","v1","auth","mfa","send"] },
        "body": { "mode": "raw", "raw": "" },
        "description": "Generates a 6-digit OTP and stores it in Redis with a 5-minute TTL. In production this triggers an SMS/email via the notification service. For now the OTP is visible in the server logs."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"message\": \"OTP sent\",\n  \"timestamp\": \"2026-06-18T12:33:00.000Z\"\n}"
        }
      ]
    },
    {
      "name": "6. MFA — Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": { "raw": "{{base_url}}/api/v1/auth/mfa/verify", "host": ["{{base_url}}"], "path": ["api","v1","auth","mfa","verify"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": \"123456\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Verifies the OTP. On success the OTP is deleted from Redis (single-use). Replace 123456 with the actual OTP from the server logs."
      },
      "response": [
        {
          "name": "200 OK — verified",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": { \"verified\": true },\n  \"message\": \"MFA verified\",\n  \"timestamp\": \"2026-06-18T12:33:30.000Z\"\n}"
        },
        {
          "name": "401 Wrong OTP",
          "status": "Unauthorized",
          "code": 401,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": { \"verified\": false },\n  \"message\": \"Invalid or expired OTP\",\n  \"timestamp\": \"2026-06-18T12:33:30.000Z\"\n}"
        }
      ]
    },
    {
      "name": "— Validation Tests —",
      "item": [
        {
          "name": "Register — weak password (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"weak@example.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Register — invalid email (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"Test@1234\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Call protected endpoint without token (expect 403)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/send", "host": ["{{base_url}}"], "path": ["api","v1","auth","mfa","send"] },
            "body": { "mode": "raw", "raw": "" }
          }
        },
        {
          "name": "Verify OTP — wrong format (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/verify", "host": ["{{base_url}}"], "path": ["api","v1","auth","mfa","verify"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"12\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
